# ============================================================
# AMRO Web Trial — Production Environment Example
# Copy to .env on the server and fill real values.
# Do not commit real .env files.
# ============================================================

# --- App ---
APP_ENV=production
APP_SECRET_KEY=replace-with-random-32-plus-character-secret
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Public URLs ---
FRONTEND_URL=https://your-domain.com
WEBHOOK_BASE_URL=https://your-domain.com

# --- PocketBase (Google login + tier) ---
# VPS: backend talks to local PB; browser uses same-origin /pb via nginx
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# --- Stripe (optional; leave blank if payments are disabled for trial) ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# --- Brain 1 / 2 / 3 (GPT-4o mini — keys only, see app/intelligence/brain_stack.py) ---
OPENAI_API_KEY_INTEL=
OPENAI_API_KEY=
OPENAI_API_KEY_JUDGE=
FINNHUB_API_KEY=
GEMINI_API_KEY=

# --- Market Data ---
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# --- Redis (optional; app currently works without relying on live Redis cache) ---
REDIS_URL=redis://localhost:6379

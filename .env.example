# ============================================================
# AMRO SaaS — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ⚠️ ห้าม commit ไฟล์ .env ขึ้น GitHub เด็ดขาด
# ============================================================

# --- App ---
APP_ENV=development          # development | production
APP_SECRET_KEY=change-this-to-random-string-min-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000

# --- PocketBase (Auth) ---
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@yourdomain.com
POCKETBASE_ADMIN_PASSWORD=your-admin-password

# --- Stripe (Payments) ---
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_ID_MONTHLY=price_xxxxxxxxxxxx   # Subscription ราย เดือน
STRIPE_PRICE_ID_YEARLY=price_xxxxxxxxxxxx    # Subscription รายปี

# --- Claude API (Audit Agent) ---
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# --- Market Data ---
# Binance (ถ้าใช้ Crypto)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# MT5 (เพิ่มทีหลัง)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# --- Redis (Signal Cache) ---
REDIS_URL=redis://localhost:6379

# --- Domain ---
FRONTEND_URL=http://localhost:3000
WEBHOOK_BASE_URL=https://yourdomain.com
